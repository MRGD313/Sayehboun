# Bale Bot Token
BALE_BOT_TOKEN=your_bale_bot_token_here

# MetisAI API Key
DEEPSEEK_API_KEY=your_metis_api_key_here

# Model via MetisAI DeepSeek endpoint
DEEPSEEK_MODEL=deepseek-chat

# Metis Bot ID (history taker — primary)
METIS_BOT_ID=your_metis_bot_id_here

# Backup history taker when primary fails once per Bale session
METIS_BOT_ID_BACKUP=your_metis_backup_bot_id_here

# Metis structure/history formatter bot ID
METIS_STRUCTURE_BOT_ID=your_metis_structure_bot_id_here
# Formatter model on Metis: deepseek / deepseek-v4-flash (prompt: tuner/prompts/history_formatter_instructions.txt)
FORMATTER_PROMPT_VERSION=v1

# Metis judging bot (sayehboun_judging_bot) — triage output for doctor
METIS_JUDGING_BOT_ID=4e2560e1-024a-49e2-b9d4-ebc233a54eae

# Doctor Bale username (auto-registers chat_id when doctor messages bot)
DOCTOR_BALE_USERNAME=your_doctor_bale_username

# Optional fallback doctor chat_id (from DB/logs if username registration fails)
DOCTOR_CHAT_ID=

# Bale polling: use Windows/VPN HTTP proxy when 1 (default: direct)
# USE_SYSTEM_PROXY=0

# Metis API: always direct (bypass VPN/proxy). Set 1 only to force Metis through proxy.
# METIS_USE_SYSTEM_PROXY=0

# Optional: SQLite database path
SQLITE_DB_PATH=bot.db

# History taker prompt tuner (tuner/tune.py)
METIS_EVALUATOR_BOT_ID=your_evaluator_bot_id_here
# Evaluator Metis model: google / gemini-3.1-pro-preview
PROMPT_VERSION=v3
METIS_HISTORY_TAKER_STAGING_BOT_ID=
METIS_TIMEOUT=180
